<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiDesktopApp.ViewModels"
             x:Class="MauiDesktopApp.Views.AdminLoginPage"
             x:DataType="vm:AdminLoginViewModel"
             Title="Connexion administrateur">
    <VerticalStackLayout Padding="20" Spacing="12" MaximumWidthRequest="420">
        <Label Text="Mode administrateur" FontSize="22" FontAttributes="Bold" />
        <Label Text="Entrez le mot de passe administrateur." />

        <Entry Placeholder="Mot de passe"
               IsPassword="True"
               Text="{Binding Password}" />

        <Button Text="Se connecter"
                Command="{Binding LoginCommand}" />

        <Label Text="{Binding ErrorMessage}" TextColor="Red" />
    </VerticalStackLayout>
</ContentPage>
